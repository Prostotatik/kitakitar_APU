<!doctype html>
<html lang="en" class="h-full">
 <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>EcoPoint - Recycling Center</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="/_sdk/element_sdk.js"></script>
  <script src="/_sdk/data_sdk.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&amp;display=swap" rel="stylesheet">
  <style>
    body {
      box-sizing: border-box;
      font-family: 'Space Grotesk', sans-serif;
    }
    .gradient-bg {
      background: linear-gradient(135deg, #0d9488 0%, #065f46 50%, #1e3a2f 100%);
    }
    .glass-card {
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.2);
    }
    .input-field {
      transition: all 0.3s ease;
    }
    .input-field:focus {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(13, 148, 136, 0.2);
    }
    .btn-primary {
      background: linear-gradient(135deg, #0d9488 0%, #065f46 100%);
      transition: all 0.3s ease;
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(13, 148, 136, 0.4);
    }
    .qr-code {
      image-rendering: pixelated;
    }
    .stat-card {
      background: linear-gradient(135deg, rgba(13, 148, 136, 0.1) 0%, rgba(6, 95, 70, 0.05) 100%);
      border: 1px solid rgba(13, 148, 136, 0.2);
    }
    .sidebar-link {
      transition: all 0.2s ease;
    }
    .sidebar-link:hover, .sidebar-link.active {
      background: rgba(13, 148, 136, 0.15);
      border-left: 3px solid #0d9488;
    }
    .material-tag {
      animation: fadeIn 0.3s ease;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: scale(0.9); }
      to { opacity: 1; transform: scale(1); }
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.7; }
    }
    .loading {
      animation: pulse 1.5s infinite;
    }
  </style>
  <style>@view-transition { navigation: auto; }</style>
 </head>
 <body class="h-full">
  <div id="app" class="h-full overflow-auto"></div>
  <script>
    // Default configuration
    const defaultConfig = {
      app_title: 'EcoPoint',
      tagline: 'Recycling Made Rewarding',
      primary_color: '#0d9488',
      secondary_color: '#065f46',
      background_color: '#f0fdf4',
      text_color: '#1e3a2f',
      accent_color: '#10b981'
    };

    let config = { ...defaultConfig };
    let currentView = 'login';
    let isAuthenticated = false;
    let centerData = null;
    let intakeHistory = [];
    let isLoading = false;

    // Material options
    const materialOptions = [
      { name: 'Plastic', icon: '🥤', defaultPrice: 0.5, minWeight: 0.1, maxWeight: 100 },
      { name: 'Paper', icon: '📄', defaultPrice: 0.3, minWeight: 0.5, maxWeight: 200 },
      { name: 'Glass', icon: '🍾', defaultPrice: 0.4, minWeight: 0.5, maxWeight: 150 },
      { name: 'Metal', icon: '🥫', defaultPrice: 0.8, minWeight: 0.1, maxWeight: 100 },
      { name: 'Electronics', icon: '📱', defaultPrice: 2.0, minWeight: 0.1, maxWeight: 50 },
      { name: 'Organic', icon: '🍂', defaultPrice: 0, minWeight: 1, maxWeight: 500 },
      { name: 'Textiles', icon: '👕', defaultPrice: 0.2, minWeight: 0.5, maxWeight: 100 },
      { name: 'Batteries', icon: '🔋', defaultPrice: 1.5, minWeight: 0.05, maxWeight: 20 }
    ];

    // Generate unique ID
    function generateId() {
      return 'id_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);
    }

    // Generate QR Code as SVG
    function generateQRCode(data) {
      const size = 200;
      const modules = 25;
      const moduleSize = size / modules;
      
      // Simple hash-based pattern generation
      let hash = 0;
      for (let i = 0; i < data.length; i++) {
        hash = ((hash << 5) - hash) + data.charCodeAt(i);
        hash = hash & hash;
      }
      
      let svg = `<svg width="${size}" height="${size}" viewBox="0 0 ${size} ${size}" xmlns="http://www.w3.org/2000/svg">`;
      svg += `<rect width="${size}" height="${size}" fill="white"/>`;
      
      // Position patterns (corners)
      const drawPositionPattern = (x, y) => {
        svg += `<rect x="${x}" y="${y}" width="${7*moduleSize}" height="${7*moduleSize}" fill="#1e3a2f"/>`;
        svg += `<rect x="${x+moduleSize}" y="${y+moduleSize}" width="${5*moduleSize}" height="${5*moduleSize}" fill="white"/>`;
        svg += `<rect x="${x+2*moduleSize}" y="${y+2*moduleSize}" width="${3*moduleSize}" height="${3*moduleSize}" fill="#1e3a2f"/>`;
      };
      
      drawPositionPattern(0, 0);
      drawPositionPattern((modules-7)*moduleSize, 0);
      drawPositionPattern(0, (modules-7)*moduleSize);
      
      // Data modules
      const seed = Math.abs(hash);
      for (let row = 0; row < modules; row++) {
        for (let col = 0; col < modules; col++) {
          // Skip position patterns
          if ((row < 8 && col < 8) || (row < 8 && col > modules-9) || (row > modules-9 && col < 8)) continue;
          
          const idx = row * modules + col;
          const bit = ((seed * (idx + 1) * 31) % 100) > 45;
          
          if (bit) {
            svg += `<rect x="${col*moduleSize}" y="${row*moduleSize}" width="${moduleSize}" height="${moduleSize}" fill="#1e3a2f"/>`;
          }
        }
      }
      
      svg += '</svg>';
      return svg;
    }

    // Data handler for SDK
    const dataHandler = {
      onDataChanged(data) {
        // Separate center data from intake history
        const centers = data.filter(d => d.type === 'center');
        const intakes = data.filter(d => d.type === 'intake');
        
        if (centers.length > 0 && isAuthenticated) {
          centerData = centers[0];
        }
        
        intakeHistory = intakes.sort((a, b) => new Date(b.created_at) - new Date(a.created_at));
        
        // Re-render if on dashboard
        if (isAuthenticated && (currentView === 'dashboard' || currentView === 'history' || currentView === 'qr-codes')) {
          render();
        }
      }
    };

    // Render functions
    function render() {
      const app = document.getElementById('app');
      
      if (!isAuthenticated) {
        if (currentView === 'register') {
          app.innerHTML = renderRegisterScreen();
        } else if (currentView === 'forgot') {
          app.innerHTML = renderForgotScreen();
        } else {
          app.innerHTML = renderLoginScreen();
        }
      } else {
        app.innerHTML = renderDashboard();
      }
      
      attachEventListeners();
    }

    function renderLoginScreen() {
      return `
        <div class="h-full gradient-bg flex items-center justify-center p-4">
          <div class="glass-card rounded-3xl shadow-2xl w-full max-w-md p-8">
            <div class="text-center mb-8">
              <div class="w-20 h-20 mx-auto mb-4 rounded-2xl bg-gradient-to-br from-teal-500 to-emerald-600 flex items-center justify-center shadow-lg">
                <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                </svg>
              </div>
              <h1 id="app-title" class="text-3xl font-bold text-gray-800">${config.app_title || defaultConfig.app_title}</h1>
              <p id="app-tagline" class="text-gray-500 mt-2">${config.tagline || defaultConfig.tagline}</p>
            </div>
            
            <form id="login-form" class="space-y-5">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Email</label>
                <input type="email" id="login-email" required
                  class="input-field w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-teal-500 focus:ring-2 focus:ring-teal-200 outline-none"
                  placeholder="center@example.com">
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Password</label>
                <input type="password" id="login-password" required
                  class="input-field w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-teal-500 focus:ring-2 focus:ring-teal-200 outline-none"
                  placeholder="••••••••">
              </div>
              
              <button type="submit" class="btn-primary w-full py-3 rounded-xl text-white font-semibold text-lg">
                Sign In
              </button>
            </form>
            
            <div class="mt-6 flex justify-between text-sm">
              <button id="goto-register" class="text-teal-600 hover:text-teal-700 font-medium">Create Account</button>
              <button id="goto-forgot" class="text-gray-500 hover:text-gray-700">Forgot Password?</button>
            </div>
          </div>
        </div>
      `;
    }

    function renderRegisterScreen() {
      return `
        <div class="h-full gradient-bg overflow-auto py-8 px-4">
          <div class="glass-card rounded-3xl shadow-2xl w-full max-w-2xl mx-auto p-8">
            <div class="text-center mb-8">
              <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-gradient-to-br from-teal-500 to-emerald-600 flex items-center justify-center shadow-lg">
                <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                </svg>
              </div>
              <h1 class="text-2xl font-bold text-gray-800">Register Recycling Center</h1>
              <p class="text-gray-500 mt-1">Join our network of eco-friendly centers</p>
            </div>
            
            <form id="register-form" class="space-y-6">
              <!-- Center Info Section -->
              <div class="bg-gray-50 rounded-2xl p-5">
                <h3 class="font-semibold text-gray-800 mb-4 flex items-center gap-2">
                  <span class="w-6 h-6 rounded-full bg-teal-100 text-teal-600 flex items-center justify-center text-sm">1</span>
