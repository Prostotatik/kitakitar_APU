            </form>
            
            <p class="mt-6 text-center text-sm text-gray-500">
              Already have an account? 
              <button id="goto-login" class="text-teal-600 hover:text-teal-700 font-medium">Sign In</button>
            </p>
          </div>
        </div>
      `;
    }

