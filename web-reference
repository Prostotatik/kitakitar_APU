                  </div>
                  <div class="md:col-span-2">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Center Address</label>
                    <div class="relative">
                      <input type="text" id="reg-address" required
                        class="input-field w-full px-4 py-2.5 pl-10 rounded-xl border border-gray-200 focus:border-teal-500 focus:ring-2 focus:ring-teal-200 outline-none"
