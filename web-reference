      `;
    }

    function renderDashboard() {
      const materials = centerData?.materials ? JSON.parse(centerData.materials) : [];
      
      // Calculate stats
      const totalIntakes = intakeHistory.length;
      const totalWeight = intakeHistory.reduce((sum, i) => sum + (i.weight || 0), 0);
      const totalPoints = intakeHistory.reduce((sum, i) => sum + (i.points_value || 0), 0);
      const scannedQRs = intakeHistory.filter(i => i.qr_used).length;
      
      return `
        <div class="h-full flex bg-gray-50">
          <!-- Sidebar -->
          <aside class="w-64 bg-white border-r border-gray-200 flex flex-col">
            <div class="p-5 border-b border-gray-100">
              <div class="flex items-center gap-3">
