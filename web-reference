                  Accepted Materials
                </h3>
                <p class="text-sm text-gray-500 mb-3">Select materials your center accepts and set pricing</p>
                <div id="materials-container" class="space-y-3">
                  ${materialOptions.map((mat, idx) => `
                    <div class="flex items-center gap-3 p-3 bg-white rounded-xl border border-gray-100">
                      <input type="checkbox" id="mat-${idx}" data-material="${mat.name}" 
                        class="material-checkbox w-5 h-5 rounded border-gray-300 text-teal-600 focus:ring-teal-500">
                      <span class="text-xl">${mat.icon}</span>
                      <span class="font-medium text-gray-700 flex-1">${mat.name}</span>
                      <div class="material-settings hidden flex items-center gap-2">
                        <div class="flex items-center gap-1">
                          <span class="text-xs text-gray-500">Min:</span>
                          <input type="number" step="0.1" value="${mat.minWeight}" 
                            class="w-16 px-2 py-1 text-sm rounded-lg border border-gray-200 mat-min" placeholder="Min kg">
                        </div>
                        <div class="flex items-center gap-1">
                          <span class="text-xs text-gray-500">Max:</span>
                          <input type="number" step="0.1" value="${mat.maxWeight}"
                            class="w-16 px-2 py-1 text-sm rounded-lg border border-gray-200 mat-max" placeholder="Max kg">
                        </div>
                        <div class="flex items-center gap-1">
                          <span class="text-xs text-gray-500">$/kg:</span>
                          <input type="number" step="0.01" value="${mat.defaultPrice}"
                            class="w-16 px-2 py-1 text-sm rounded-lg border border-gray-200 mat-price" placeholder="Price">
                        </div>
                        <label class="flex items-center gap-1 text-xs text-gray-500">
                          <input type="checkbox" class="mat-free rounded text-teal-600">
                          Free
                        </label>
                      </div>
                    </div>
                  `).join('')}
                </div>
              </div>

              <!-- Manager Info Section -->
              <div class="bg-gray-50 rounded-2xl p-5">
                <h3 class="font-semibold text-gray-800 mb-4 flex items-center gap-2">
                  <span class="w-6 h-6 rounded-full bg-teal-100 text-teal-600 flex items-center justify-center text-sm">3</span>
