            `}
          </div>
        </div>
      `;
    }

    // Event listeners
    function attachEventListeners() {
      // Login form
      const loginForm = document.getElementById('login-form');
      if (loginForm) {
        loginForm.addEventListener('submit', handleLogin);
      }
      
      // Register form
      const registerForm = document.getElementById('register-form');
      if (registerForm) {
        registerForm.addEventListener('submit', handleRegister);
        
        // Material checkbox listeners
        document.querySelectorAll('.material-checkbox').forEach(checkbox => {
          checkbox.addEventListener('change', (e) => {
            const settings = e.target.closest('.flex').querySelector('.material-settings');
            if (settings) {
              settings.classList.toggle('hidden', !e.target.checked);
            }
          });
        });
        
        // Free checkbox listeners
        document.querySelectorAll('.mat-free').forEach(checkbox => {
          checkbox.addEventListener('change', (e) => {
            const priceInput = e.target.closest('.material-settings').querySelector('.mat-price');
            if (priceInput) {
              priceInput.disabled = e.target.checked;
              if (e.target.checked) priceInput.value = '0';
            }
          });
        });
      }
      
      // Forgot form
      const forgotForm = document.getElementById('forgot-form');
      if (forgotForm) {
        forgotForm.addEventListener('submit', handleForgotPassword);
      }
      
      // Profile form
      const profileForm = document.getElementById('profile-form');
      if (profileForm) {
        profileForm.addEventListener('submit', handleProfileUpdate);
      }
      
      // Intake form
      const intakeForm = document.getElementById('intake-form');
      if (intakeForm) {
        intakeForm.addEventListener('submit', handleNewIntake);
        
        // Update weight hint based on selected material
        const materials = centerData?.materials ? JSON.parse(centerData.materials) : [];
        document.querySelectorAll('input[name="material"]').forEach(radio => {
          radio.addEventListener('change', (e) => {
            const mat = materials.find(m => m.name === e.target.value);
            const hint = document.getElementById('weight-hint');
            if (hint && mat) {
              hint.textContent = `Min: ${mat.minWeight} kg | Max: ${mat.maxWeight} kg | ${mat.free ? 'Free service' : '$' + mat.price + '/kg'}`;
            }
          });
        });
        
        // Trigger initial hint
        const selectedMat = document.querySelector('input[name="material"]:checked');
        if (selectedMat) {
          selectedMat.dispatchEvent(new Event('change'));
        }
      }
      
      // Navigation
      document.getElementById('goto-register')?.addEventListener('click', () => {
        currentView = 'register';
        render();
      });
      
      document.getElementById('goto-forgot')?.addEventListener('click', () => {
        currentView = 'forgot';
        render();
      });
      
      document.querySelectorAll('#goto-login').forEach(btn => {
        btn.addEventListener('click', () => {
          currentView = 'login';
          render();
        });
      });
      
      // Sidebar navigation
      document.querySelectorAll('[data-view]').forEach(btn => {
        btn.addEventListener('click', (e) => {
          currentView = e.currentTarget.dataset.view;
          render();
        });
      });
      
      // Logout
      document.getElementById('logout-btn')?.addEventListener('click', () => {
        isAuthenticated = false;
        centerData = null;
        currentView = 'login';
        render();
      });
      
      // Simulate QR scan
      document.querySelectorAll('.simulate-scan').forEach(btn => {
        btn.addEventListener('click', handleSimulateScan);
      });
    }

    async function handleLogin(e) {
      e.preventDefault();
      const email = document.getElementById('login-email').value;
      const password = document.getElementById('login-password').value;
      
      // Find center with matching credentials
      const centers = intakeHistory.length === 0 ? [] : [];
      
      // For demo purposes, check if we have any center data
      // In a real app, you'd validate against stored credentials
      if (email && password) {
        isAuthenticated = true;
        currentView = 'dashboard';
        render();
      }
    }

    async function handleRegister(e) {
      e.preventDefault();
      const errorDiv = document.getElementById('register-error');
      const btn = document.getElementById('register-btn');
      
      const password = document.getElementById('reg-password').value;
      const confirmPassword = document.getElementById('reg-confirm-password').value;
      
      if (password !== confirmPassword) {
        errorDiv.textContent = 'Passwords do not match';
        errorDiv.classList.remove('hidden');
        return;
      }
      
      // Collect materials
      const materials = [];
      document.querySelectorAll('.material-checkbox:checked').forEach(checkbox => {
        const container = checkbox.closest('.flex');
        const settings = container.querySelector('.material-settings');
        materials.push({
          name: checkbox.dataset.material,
          minWeight: parseFloat(settings.querySelector('.mat-min').value) || 0.1,
          maxWeight: parseFloat(settings.querySelector('.mat-max').value) || 100,
          price: parseFloat(settings.querySelector('.mat-price').value) || 0,
          free: settings.querySelector('.mat-free').checked
        });
      });
      
      if (materials.length === 0) {
        errorDiv.textContent = 'Please select at least one material';
        errorDiv.classList.remove('hidden');
        return;
      }
      
      btn.disabled = true;
      btn.innerHTML = '<span class="loading">Creating account...</span>';
      
      const newCenter = {
        type: 'center',
        center_name: document.getElementById('reg-center-name').value,
        center_address: document.getElementById('reg-address').value,
        manager_name: document.getElementById('reg-manager-name').value,
        manager_phone: document.getElementById('reg-manager-phone').value,
        email: document.getElementById('reg-email').value,
        password: password, // In production, hash this!
        materials: JSON.stringify(materials),
        created_at: new Date().toISOString()
      };
      
      const result = await window.dataSdk.create(newCenter);
      
      btn.disabled = false;
      btn.innerHTML = 'Register Center';
      
      if (result.isOk) {
        centerData = newCenter;
        isAuthenticated = true;
        currentView = 'dashboard';
        render();
      } else {
        errorDiv.textContent = 'Registration failed. Please try again.';
        errorDiv.classList.remove('hidden');
      }
    }

    function handleForgotPassword(e) {
      e.preventDefault();
      const messageDiv = document.getElementById('forgot-message');
      messageDiv.textContent = 'If an account exists with this email, you will receive reset instructions.';
      messageDiv.className = 'text-sm text-center p-3 rounded-xl bg-green-50 text-green-700';
      messageDiv.classList.remove('hidden');
    }

    async function handleProfileUpdate(e) {
      e.preventDefault();
      const btn = document.getElementById('save-profile-btn');
      const messageDiv = document.getElementById('profile-message');
      
      if (!centerData?.__backendId) {
        messageDiv.textContent = 'No center data found';
        messageDiv.className = 'text-sm text-center p-3 rounded-xl bg-red-50 text-red-500';
        messageDiv.classList.remove('hidden');
        return;
      }
      
      btn.disabled = true;
      btn.innerHTML = '<span class="loading">Saving...</span>';
      
      const updatedCenter = {
        ...centerData,
        center_name: document.getElementById('profile-center-name').value,
        center_address: document.getElementById('profile-address').value,
        manager_name: document.getElementById('profile-manager-name').value,
        manager_phone: document.getElementById('profile-manager-phone').value
      };
      
      const result = await window.dataSdk.update(updatedCenter);
      
      btn.disabled = false;
      btn.innerHTML = 'Save Changes';
      
      if (result.isOk) {
        messageDiv.textContent = 'Profile updated successfully!';
        messageDiv.className = 'text-sm text-center p-3 rounded-xl bg-green-50 text-green-700';
      } else {
        messageDiv.textContent = 'Failed to update profile';
        messageDiv.className = 'text-sm text-center p-3 rounded-xl bg-red-50 text-red-500';
      }
      messageDiv.classList.remove('hidden');
    }

    async function handleNewIntake(e) {
      e.preventDefault();
      const errorDiv = document.getElementById('intake-error');
      const btn = document.getElementById('generate-qr-btn');
      const resultDiv = document.getElementById('qr-result');
      
      const selectedMaterial = document.querySelector('input[name="material"]:checked');
      const weight = parseFloat(document.getElementById('intake-weight').value);
      
      if (!selectedMaterial) {
        errorDiv.textContent = 'Please select a material';
        errorDiv.classList.remove('hidden');
        return;
      }
      
      const materials = centerData?.materials ? JSON.parse(centerData.materials) : [];
      const mat = materials.find(m => m.name === selectedMaterial.value);
      
      if (!mat) {
        errorDiv.textContent = 'Invalid material selection';
        errorDiv.classList.remove('hidden');
        return;
      }
      
      if (weight < mat.minWeight || weight > mat.maxWeight) {
        errorDiv.textContent = `Weight must be between ${mat.minWeight} and ${mat.maxWeight} kg`;
        errorDiv.classList.remove('hidden');
        return;
      }
      
      // Check data limit
      if (intakeHistory.length >= 999) {
        errorDiv.textContent = 'Maximum data limit reached. Please delete some old records.';
        errorDiv.classList.remove('hidden');
        return;
      }
      
      errorDiv.classList.add('hidden');
      btn.disabled = true;
      btn.innerHTML = '<span class="loading">Generating QR Code...</span>';
      
      const intakeId = generateId();
      const qrCode = `ECO-${intakeId}-${Date.now()}`;
      const pointsValue = mat.free ? Math.round(weight * 10) : Math.round(weight * mat.price * 10);
      
      const newIntake = {
        type: 'intake',
        intake_id: intakeId,
        material_type: mat.name,
        weight: weight,
        points_value: pointsValue,
        qr_code: qrCode,
        qr_used: false,
        created_at: new Date().toISOString(),
        scanned_at: null
      };
      
      const result = await window.dataSdk.create(newIntake);
      
      btn.disabled = false;
      btn.innerHTML = `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"/>
      </svg> Generate QR Code`;
      
      if (result.isOk) {
        const matOption = materialOptions.find(m => m.name === mat.name);
        document.getElementById('qr-code-container').innerHTML = generateQRCode(qrCode);
        document.getElementById('qr-details').innerHTML = `
          <p><strong>${matOption?.icon || '♻️'} ${mat.name}</strong> • ${weight} kg</p>
          <p class="text-teal-600 font-semibold">${pointsValue} points</p>
        `;
        resultDiv.classList.remove('hidden');
        
        // Reset form
        document.getElementById('intake-weight').value = '';
      } else {
        errorDiv.textContent = 'Failed to create intake. Please try again.';
        errorDiv.classList.remove('hidden');
      }
    }

    async function handleSimulateScan(e) {
      const id = e.target.dataset.id;
      const intake = intakeHistory.find(i => i.__backendId === id);
      
      if (!intake || intake.qr_used) return;
      
      e.target.disabled = true;
      e.target.textContent = 'Processing...';
      
      const updatedIntake = {
        ...intake,
        qr_used: true,
        scanned_at: new Date().toISOString()
      };
      
      const result = await window.dataSdk.update(updatedIntake);
      
      if (result.isOk) {
        render();
      } else {
        e.target.disabled = false;
        e.target.textContent = 'Simulate Scan';
      }
    }

