                </div>
              </div>

              <div id="register-error" class="hidden text-red-500 text-sm text-center bg-red-50 p-3 rounded-xl"></div>

              <button type="submit" id="register-btn" class="btn-primary w-full py-3 rounded-xl text-white font-semibold text-lg">
                Register Center
